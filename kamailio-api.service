[Unit]
Description=Kamailio Subscriber + Device API Server
Documentation=https://github.com/triangletrade2022-lgtm/vpn.net2app
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/node /home/debian/voip-v3/kamailio-api-server.js
Restart=always
RestartSec=5
User=root
WorkingDirectory=/home/debian/voip-v3
StandardOutput=append:/var/log/kamailio-api.log
StandardError=append:/var/log/kamailio-api.log
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
